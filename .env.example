# Copy this file to .env and fill in your key to enable LLM-backed reasoning.
#   copy .env.example .env      (Windows)
#   cp .env.example .env        (macOS / Linux)
# The .env file is gitignored. Never commit real secrets.

# Turn on the Anthropic-backed reasoning engine.
POC_REASONING=anthropic

# Your Anthropic API key.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the model (defaults to claude-opus-4-8).
# POC_REASONING_MODEL=claude-opus-4-8
