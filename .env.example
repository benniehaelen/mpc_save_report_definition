# Copy this file to .env and fill in your key to enable LLM-backed reasoning.
#   copy .env.example .env      (Windows)
#   cp .env.example .env        (macOS / Linux)
# The .env file is gitignored. Never commit real secrets.

# Turn on the Anthropic-backed reasoning engine.
POC_REASONING=anthropic

# Turn on the Anthropic-backed structure extractor, which proposes derived
# queries, charts, and narrative tiers for a free-form artifact. Off by default:
# the deterministic extractor infers nothing and needs no network.
# POC_DISTILLER=anthropic

# Your Anthropic API key.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the models (both default to claude-opus-4-8).
# POC_REASONING_MODEL=claude-opus-4-8
# POC_DISTILLER_MODEL=claude-opus-4-8
